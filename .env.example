# ===========================
# SFMS Environment Variables
# ===========================

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=sfms_db

# JWT
JWT_ACCESS_SECRET=sfms_access_secret_dev_2024_replace_in_production
JWT_REFRESH_SECRET=sfms_refresh_secret_dev_2024_replace_in_production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Server
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# File Uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# Logging
LOG_LEVEL=debug
LOG_DIR=logs
